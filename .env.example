# =========================================================
# Repo Context MCP - Environment Variables Example
# =========================================================
#
# Environment variables are optional.
#
# You can:
# - use a local .env file
# - export variables in your shell
# - inject variables through Claude Desktop
# - inject variables through CI/CD
#
# Example usage in config/sources.yaml:
#
# token: ${GITHUB_TOKEN}
#
# =========================================================

# =========================================================
# GitHub
# =========================================================

# Public GitHub usually does not require a token,
# but rate limits are much lower without one.

GITHUB_TOKEN=

# GitHub Enterprise / self-hosted GitHub
GITHUB_ENTERPRISE_TOKEN=

# =========================================================
# GitLab
# =========================================================

# Public GitLab projects can work without a token.
# Private projects require a token with read_repository access.

GITLAB_TOKEN=

# Self-managed GitLab
GITLAB_SELF_MANAGED_TOKEN=

# =========================================================
# Bitbucket
# =========================================================

# Bitbucket Cloud App Password / token
BITBUCKET_TOKEN=

# Bitbucket Data Center / Server token
BITBUCKET_DC_TOKEN=

# =========================================================
# Optional Generic Tokens
# =========================================================
#
# These are not used automatically by the project,
# but can be referenced in sources.yaml if desired.
#
# Example:
#
# token: ${PLATFORM_TOKEN}
#
# =========================================================

PLATFORM_TOKEN=
CODE_HOSTING_TOKEN=
DEVOPS_TOKEN=

# =========================================================
# Optional Future Provider Support
# =========================================================
#
# Reserved for future integrations.
#
# =========================================================

AZURE_DEVOPS_TOKEN=
GITEA_TOKEN=
FORGEJO_TOKEN=